# ==========================================
# KONFIGURACJA EWIDENCJI PRZEBIEGU POJAZDÓW
# ==========================================
# Skopiuj ten plik jako .env i uzupełnij wartości

# === BAZA DANYCH ===
# Przy użyciu Docker Compose (domyślnie):
DATABASE_URL="postgresql://ewidencja:ZMIEN_NA_BEZPIECZNE_HASLO@db:5432/ewidencja_przebiegu"

# Przy lokalnej instalacji PostgreSQL:
# DATABASE_URL="postgresql://user:password@localhost:5432/ewidencja_przebiegu"

# === APLIKACJA ===
# URL pod którym aplikacja jest dostępna
NEXTAUTH_URL=http://localhost:3000

# Sekret do szyfrowania sesji (wygeneruj: openssl rand -base64 32)
NEXTAUTH_SECRET=ZMIEN_NA_LOSOWY_CIAG_MINIMUM_32_ZNAKI

# === AI / LLM (opcjonalne - do parsowania wyciągów i faktur PDF) ===
# OPCJA 1: Klucz Abacus AI (zalecany - najlepsza jakość)
ABACUSAI_API_KEY=s2_...
# OPCJA 2: Klucz OpenAI (alternatywa)
OPENAI_API_KEY=sk-...
# URL API (domyślnie OpenAI, ale można ustawić inny np. dla Ollama)
OPENAI_API_URL=https://api.openai.com/v1
# Model do użycia (ignorowany gdy ABACUSAI_API_KEY jest ustawiony)
OPENAI_MODEL=gpt-4o-mini

# === DOCKER COMPOSE ===
DB_USER=ewidencja
DB_PASSWORD=ZMIEN_NA_BEZPIECZNE_HASLO
DB_NAME=ewidencja_przebiegu
DB_PORT=5432
APP_PORT=3000
